# Hermes Real-Time Voice - Configuration
# Copy to .env and fill in your values

# --- Twilio ---
TWILIO_SID=AC...
TWILIO_TOKEN=...
TWILIO_NUMBER=+1...

# --- Groq for speech recognition ---
GROQ_KEY=gsk_...

# --- ElevenLabs for speech synthesis ---
ELEVENLABS_KEY=sk_...
ELEVENLABS_VOICE=K9DhA3x8BzZ1PmR6sTfW    # Irish en-IE-EmilyNeural
ELEVENLABS_MODEL=eleven_turbo_v2_5

# --- OpenRouter for Hermes LLM ---
OPENROUTER_KEY=sk-or-v1-...
OPENROUTER_MODEL=deepseek/deepseek-v4-pro

# --- Pipeline settings ---
PIPECAT_HOST=localhost
PIPECAT_PORT=8080
PIPECAT_PUBLIC_HOST=voice.reneetoufee.com
VAD_SILENCE_MS=500
VAD_THRESHOLD=0.5

# --- Optional: restrict to your number only ---
ALLOWED_CALLER=+1...
